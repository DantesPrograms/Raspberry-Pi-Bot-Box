# SH1106 is the safest default for 1.3" 128x64 OLED modules.
OLED_CONTROLLER=sh1106

# A board marked 0x78 / 0x7A is usually 0x3C / 0x3D in Linux.
OLED_I2C_DEVICE=/dev/i2c-1
OLED_I2C_ADDRESS=0x3c

# Rotate pages every 5 seconds and refresh stats once per second.
DASHBOARD_PAGE_SECONDS=5
DASHBOARD_REFRESH_MS=1000

# Your Python bot can write up to 5 custom lines here for the BOT STATUS page.
BOT_STATUS_FILE=/opt/rpi-bot/state/dashboard.txt
