# Raspberry Pi pin and display config

# OLED wiring
OLED_SDA_GPIO=2
OLED_SCL_GPIO=3
OLED_SDA_PHYSICAL_PIN=3
OLED_SCL_PHYSICAL_PIN=5
OLED_I2C_DEVICE=/dev/i2c-1
OLED_I2C_ADDRESS=0x3c
OLED_CONTROLLER=sh1106

# Original joystick wiring from notes.
# The current dashboard auto-rotates pages and does not use these pins.
#V0.1 Uses GPIO23 and GPIO24 for VRX and VRY respectively
JOYSTICK_VRX_GPIO=23
JOYSTICK_VRY_GPIO=24

# Dashboard behavior
DASHBOARD_PAGE_SECONDS=5
DASHBOARD_REFRESH_MS=1000
BOT_STATUS_FILE=/opt/rpi-bot/state/dashboard.txt
